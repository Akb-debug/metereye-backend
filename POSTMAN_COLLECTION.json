          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/readings/historique/1?startDate=2026-04-01&endDate=2026-04-30&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["readings", "historique", "1"]
            }
          }
        },
        {
          "name": "Dernier Relevé",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
