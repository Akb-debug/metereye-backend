            "body": {
              "mode": "raw",
              "raw": "{\n  \"compteurId\": 1,\n  \"valeur\": 1525.5,\n  \"commentaire\": \"Lecture manuelle du 13/04/2026\"\n}",
              "options": {
                "raw": {
